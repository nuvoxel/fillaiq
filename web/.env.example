# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/fillaiq?sslmode=disable

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Microsoft OAuth (Azure AD)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MQTT Broker (WebSocket URL for frontend/devices)
MQTT_BROKER_URL=mqtt://localhost:1883
