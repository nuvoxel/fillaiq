# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/fillaiq?sslmode=disable

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Microsoft OAuth (Azure AD)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Azure Communication Services (Email)
ACS_CONNECTION_STRING=endpoint=https://<name>.unitedstates.communication.azure.com/;accesskey=<key>
ACS_SENDER_ADDRESS=DoNotReply@<guid>.azurecomm.net

# MQTT Broker (WebSocket URL for frontend/devices)
MQTT_BROKER_URL=mqtt://localhost:1883

# Azure Blob Storage (uploads)
# In prod: uses managed identity via AZURE_STORAGE_ACCOUNT (set in Helm values)
# In dev: use a connection string
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net
