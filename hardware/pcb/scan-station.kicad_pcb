    (pad "31" thru_hole circle (at 2.54 25.40) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 9 "OLED_DC"))
    (pad "32" thru_hole circle (at 2.54 27.94) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "33" thru_hole circle (at 2.54 30.48) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 10 "HX711_SCK"))
    (pad "34" thru_hole circle (at 2.54 33.02) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 11 "HX711_DT"))
    (pad "35" thru_hole circle (at 2.54 35.56) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
