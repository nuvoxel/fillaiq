    (pad "23" thru_hole circle (at 2.54 5.08) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "24" thru_hole circle (at 2.54 7.62) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
