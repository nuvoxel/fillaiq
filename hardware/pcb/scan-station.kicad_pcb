  (segment (start 122.54 110.24) (end 128.0 110.24) (width 0.25) (layer "F.Cu") (net 7) (uuid "t0000010-0000-0000-0000-000000000001"))
  (segment (start 128.0 110.24) (end 140.0 98.24) (width 0.25) (layer "F.Cu") (net 7) (uuid "t0000011-0000-0000-0000-000000000001"))
  (segment (start 140.0 98.24) (end 140.0 88.16) (width 0.25) (layer "F.Cu") (net 7) (uuid "t0000012-0000-0000-0000-000000000001"))

