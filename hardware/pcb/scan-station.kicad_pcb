  ;; ==================== J1: PN532 I2C (1x4 header) ====================
  ;; Placed to the left of the ESP32, near the I2C pins
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical"
    (layer "F.Cu")
    (uuid "f0000002-0000-0000-0000-000000000001")
    (at 108.0 85.0)
    (property "Reference" "J1"
      (at 0 -3.0 0)
      (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (property "Value" "PN532_I2C"
      (at 0 12.0 0)
      (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    ;; Pin 1=GND, 2=VCC(5V), 3=SDA, 4=SCL
    (pad "1" thru_hole rect (at 0 0) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND"))
    (pad "2" thru_hole circle (at 0 2.54) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 3 "+5V"))
    (pad "3" thru_hole circle (at 0 5.08) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 4 "I2C_SDA"))
    (pad "4" thru_hole circle (at 0 7.62) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 5 "I2C_SCL"))
  )

  ;; ==================== J2: SSD1322 OLED (2x8 header) ====================
  ;; Placed at the top of the board
  (footprint "Connector_PinHeader_2.54mm:PinHeader_2x08_P2.54mm_Vertical"
    (layer "F.Cu")
    (uuid "f0000003-0000-0000-0000-000000000001")
    (at 140.0 78.0)
    (property "Reference" "J2"
      (at 0 -3.0 0)
      (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (property "Value" "SSD1322_256x64"
      (at 0 22.0 0)
      (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    ;; Left column: pins 1-8 (x=0), Right column: pins 9-16 (x=2.54)
    ;; Pin 1=VSS(GND), 2=VCC(3V3), 3=NC, 4=D0/CLK, 5=D1/DIN, 6-8=parallel(NC)
    ;; Pin 9-11=parallel(NC), 12=E/RD#(NC), 13=R/W#(GND), 14=D/C#, 15=RES#(NC), 16=CS#
    (pad "1" thru_hole rect (at 0 0) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND"))
    (pad "2" thru_hole circle (at 0 2.54) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 2 "+3V3"))
    (pad "3" thru_hole circle (at 0 5.08) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "4" thru_hole circle (at 0 7.62) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 6 "SPI_SCK"))
    (pad "5" thru_hole circle (at 0 10.16) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 7 "SPI_MOSI"))
    (pad "6" thru_hole circle (at 0 12.70) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "7" thru_hole circle (at 0 15.24) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "8" thru_hole circle (at 0 17.78) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "9" thru_hole circle (at 2.54 0) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "10" thru_hole circle (at 2.54 2.54) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "11" thru_hole circle (at 2.54 5.08) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "12" thru_hole circle (at 2.54 7.62) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "13" thru_hole circle (at 2.54 10.16) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND"))
    (pad "14" thru_hole circle (at 2.54 12.70) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 9 "OLED_DC"))
    (pad "15" thru_hole circle (at 2.54 15.24) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "16" thru_hole circle (at 2.54 17.78) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 8 "OLED_CS"))
  )

  ;; ==================== U2: HX711 digital side (1x4 header) ====================
  ;; Right side of board: VCC, DT, SCK, GND
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical"
    (layer "F.Cu")
    (uuid "f0000004-0000-0000-0000-000000000001")
    (at 155.0 100.0)
    (property "Reference" "U2"
      (at 0 -3.0 0)
      (layer "F.SilkS")
