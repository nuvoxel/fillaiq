    (pad "15" thru_hole circle (at 0 35.56) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 5 "I2C_SCL"))
    (pad "16" thru_hole circle (at 0 38.10) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "17" thru_hole circle (at 0 40.64) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "18" thru_hole circle (at 0 43.18) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
