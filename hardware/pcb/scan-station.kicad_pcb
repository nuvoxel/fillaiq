    (property "Value" "HX711"
      (at 0 12.0 0)
      (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    ;; Pin 1=VCC(3V3), 2=DT, 3=SCK, 4=GND
    (pad "1" thru_hole rect (at 0 0) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 2 "+3V3"))
    (pad "2" thru_hole circle (at 0 2.54) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 11 "HX711_DT"))
    (pad "3" thru_hole circle (at 0 5.08) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 10 "HX711_SCK"))
    (pad "4" thru_hole circle (at 0 7.62) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND"))
  )

  ;; ==================== J4: Load Cell (1x4 header) ====================
  ;; Right edge, next to HX711
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical"
